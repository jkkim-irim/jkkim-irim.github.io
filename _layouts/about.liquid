---
layout: default
---

{% comment %}
  Single-page layout for jkkim-irim's personal site (local override of al_folio_core's about.liquid).
  Top: profile photo (left) + name / subtitle / bio / link buttons (right).
  Then, on one page: Publications -> Experience -> Projects. No news, no nav tabs.
{% endcomment %}

{% comment %}
  ===== Robot avatar: ALLEX right hand that follows the cursor =====
  three.js + urdf-loader (CDN, importmap). Model assets live under
  /assets/models/allex/. The importmap must precede the first ES module script
  on the page (al-folio's ninja-keys search loads later in <body>), so this block
  sits at the top of the content. allex.js is deferred (type=module) and disables
  itself on mobile / prefers-reduced-motion. The index fingertip tracks the cursor
  and curls while the mouse is held. Meshes are Draco-compressed .drc (~180 KB;
  decoded via DRACOLoader — CSP relaxed in _includes/head.liquid to allow its
  blob worker + WASM). Model: ALLEX by WIRobotics (right-hand subtree).
{% endcomment %}
{% comment %}
  A second avatar — the HyperLeg biped — walks along the bottom of the viewport
  following the cursor's X (run when far, walk when near), rendered BEHIND the
  page content. Its model is extracted from HyperLeg.usd → URDF + Draco meshes.
{% endcomment %}
{% comment %} Warm up the CDNs (three, urdf-loader, Draco decoder) and prefetch the modules + URDFs. {% endcomment %}
<link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin>
<link rel="preconnect" href="https://esm.sh" crossorigin>
<link rel="modulepreload" href="{{ '/assets/js/allex.js' | relative_url }}">
<link rel="modulepreload" href="{{ '/assets/js/hyperleg.js' | relative_url }}">
<link rel="preload" href="{{ '/assets/models/allex/ALLEX_Right_Hand.urdf' | relative_url }}" as="fetch" crossorigin>
<link rel="preload" href="{{ '/assets/models/hyperleg/HyperLeg.urdf' | relative_url }}" as="fetch" crossorigin>
<canvas id="robot-canvas"></canvas>
<canvas id="hyperleg-canvas"></canvas>
<script>
  // Baseurl-safe asset paths; reparent both canvases to <body> so they live in
  // the root stacking context (hand on top at z 3000, walker behind at z 0).
  window.ALLEX_ASSETS = "{{ '/assets/models/allex/' | relative_url }}";
  window.HYPERLEG_ASSETS = "{{ '/assets/models/hyperleg/' | relative_url }}";
  (function () {
    ['robot-canvas', 'hyperleg-canvas'].forEach(function (id) {
      var c = document.getElementById(id);
      if (c && c.parentNode !== document.body) document.body.appendChild(c);
    });
  })();
</script>
<script type="importmap">
{
  "imports": {
    "three": "https://cdn.jsdelivr.net/npm/three@0.160.0/build/three.module.js",
    "three/addons/": "https://cdn.jsdelivr.net/npm/three@0.160.0/examples/jsm/",
    "three/examples/jsm/": "https://cdn.jsdelivr.net/npm/three@0.160.0/examples/jsm/",
    "urdf-loader": "https://esm.sh/urdf-loader@0.12.6?external=three"
  }
}
</script>
<script type="module" src="{{ '/assets/js/allex.js' | relative_url }}"></script>
<script type="module" src="{{ '/assets/js/hyperleg.js' | relative_url }}"></script>

<div class="post">
  <article>
    {% comment %} ===== HERO ===== {% endcomment %}
    {% if page.profile and page.profile.image %}
      {% assign profile_image_path = page.profile.image | prepend: 'assets/img/' %}
      {% if page.profile.image_circular %}
        {% assign profile_image_class = 'img-fluid z-depth-1 rounded-circle' %}
      {% else %}
        {% assign profile_image_class = 'img-fluid z-depth-1 rounded' %}
      {% endif %}
      {% capture sizes %}(min-width: 576px) 240px, 60vw{% endcapture %}
      <div class="about-hero">
        <div class="about-hero-photo">
          {%
            include figure.liquid loading="eager" path=profile_image_path class=profile_image_class sizes=sizes alt=page.profile.image
            cache_bust=true
          %}
        </div>
        <div class="about-hero-text">
          <h1 class="post-title">
            {% if site.title == 'blank' %}
              <span class="font-weight-bold">{{ site.first_name }}</span> {{ site.middle_name }}
              {{ site.last_name }}
            {% else %}
              {{ site.title }}
            {% endif %}
          </h1>
          {% if page.subtitle %}<p class="desc">{{ page.subtitle }}</p>{% endif %}
          <div class="clearfix">{{ content }}</div>

          {% comment %} ----- link buttons ----- {% endcomment %}
          {% assign s = site.data.socials %}
          <div class="about-links">
            {% if s.github_username %}
              <a class="btn btn-sm z-depth-0" href="https://github.com/{{ s.github_username }}" target="_blank" rel="noopener" title="GitHub">
                <i class="fa-brands fa-github"></i> GitHub
              </a>
            {% endif %}
            {% if s.linkedin_username %}
              <a class="btn btn-sm z-depth-0" href="https://www.linkedin.com/in/{{ s.linkedin_username }}" target="_blank" rel="noopener" title="LinkedIn">
                <i class="fa-brands fa-linkedin"></i> LinkedIn
              </a>
            {% endif %}
            <a class="btn btn-sm z-depth-0" href="{{ '/cv/' | relative_url }}" title="CV">
              <i class="ai ai-cv"></i> CV
            </a>
            {% if s.scholar_userid %}
              <a class="btn btn-sm z-depth-0" href="https://scholar.google.com/citations?user={{ s.scholar_userid }}" target="_blank" rel="noopener" title="Google Scholar">
                <i class="ai ai-google-scholar"></i> Google Scholar
              </a>
            {% endif %}
          </div>
        </div>
      </div>
    {% endif %}

    {% comment %} ===== PUBLICATIONS ===== {% endcomment %}
    <h2 class="section-title">Publications</h2>
    <div class="publications">
      {% bibliography %}
    </div>

    {% comment %} ===== EXPERIENCE (edit in _data/experience.yml) ===== {% endcomment %}
    <h2 class="section-title">Experience</h2>
    {% assign experience = site.data.experience %}
    {% if experience and experience.size > 0 %}
      <div class="exp-list">
        {% for item in experience %}
          <div class="exp-item">
            {% if item.logo %}
              <div class="exp-logo">
                {% if item.url %}<a href="{{ item.url }}" target="_blank" rel="noopener">{% endif %}
                <img src="{{ item.logo | prepend: '/assets/img/' | relative_url }}" alt="{{ item.company }} logo" loading="lazy">
                {% if item.url %}</a>{% endif %}
              </div>
            {% endif %}
            <div class="exp-body">
              <div class="exp-line">
                <span class="exp-role">{{ item.position }}</span>{% if item.company %} · <span class="exp-org">{% if item.url %}<a href="{{ item.url }}" target="_blank" rel="noopener">{{ item.company }}</a>{% else %}{{ item.company }}{% endif %}</span>{% endif %}
                {% if item.start_date or item.end_date %}
                  <span class="exp-date">{{ item.start_date }}{% if item.end_date %} – {{ item.end_date }}{% endif %}</span>
                {% endif %}
              </div>
              {% if item.location %}<div class="exp-loc">{{ item.location }}</div>{% endif %}
              {% if item.summary %}<p class="exp-summary">{{ item.summary }}</p>{% endif %}
              {% if item.highlights %}
                <ul>
                  {% for h in item.highlights %}<li>{{ h }}</li>{% endfor %}
                </ul>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    {% else %}
      <p>Experience entries are managed in <code>_data/experience.yml</code>.</p>
    {% endif %}

    {% comment %} ===== PROJECTS ===== {% endcomment %}
    <h2 class="section-title">Projects</h2>
    <div class="projects">
      <div class="row row-cols-1">
        {% assign sorted_projects = site.projects | sort: 'importance' %}
        {% for project in sorted_projects %}
          {% include projects_horizontal.liquid %}
        {% endfor %}
      </div>
    </div>
  </article>
</div>

<style>
  /* ===== Robot avatars ===== */
  /* ALLEX hand — always on top of everything */
  #robot-canvas {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 3000;         /* always on top (above nav/footer at z 1030) */
    pointer-events: none;  /* never blocks clicks/selection */
    opacity: 1;
  }
  /* HyperLeg walker — pinned to the bottom, behind page content */
  #hyperleg-canvas {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;            /* behind content */
    pointer-events: none;
    opacity: 0.95;
  }
  /* keep page content above the walker (hand stays above at z 3000) */
  .post { position: relative; z-index: 1; }

  /* ===== Claude-inspired warm palette (overrides al-folio theme vars) ===== */
  :root {
    --global-bg-color: #faf9f5;
    --global-text-color: #2b2a27;
    --global-text-color-light: #7a776e;
    --global-theme-color: #8f6a45;
    --global-hover-color: #8f6a45;
    --global-hover-text-color: #ffffff;
    --global-divider-color: rgba(60, 55, 45, 0.12);
    --global-card-bg-color: #ffffff;
    --global-code-bg-color: rgba(143, 106, 69, 0.08);
    --global-highlight-color: #8f6a45;
    --global-footer-bg-color: #2b2a27;
    --global-footer-text-color: #e8e4da;
    --global-footer-link-color: #ffffff;
  }
  html[data-theme="dark"] {
    --global-bg-color: #22201c;
    --global-text-color: #ece8de;
    --global-text-color-light: #a8a499;
    --global-theme-color: #c7a173;
    --global-hover-color: #c7a173;
    --global-hover-text-color: #22201c;
    --global-divider-color: rgba(255, 255, 255, 0.12);
    --global-card-bg-color: #2a2823;
    --global-code-bg-color: rgba(199, 161, 115, 0.12);
    --global-highlight-color: #c7a173;
    --global-footer-bg-color: #191713;
  }

  /* ===== Venue badges: colored bg, text always white (light & dark) ===== */
  /* High-specificity rule to beat gem's `.publications ... .abbr abbr { color: var(--global-card-bg-color) }`
     which turns dark in dark mode and made badge text invisible. */
  .publications ol.bibliography li .abbr abbr,
  .badge {
    color: #ffffff !important;
  }
  .badge.venue-iros {
    background-color: #23406b !important; /* deep blue */
    color: #ffffff !important;
  }
  .badge.venue-preprint {
    background-color: #e0a23c !important; /* amber (orange–yellow) */
    color: #ffffff !important;
  }

  /* ===== Hide the big year group header in publications ===== */
  .publications h2.bibliography {
    display: none;
  }

  .about-hero {
    display: flex;
    align-items: flex-start;
    gap: 2rem;
    margin-bottom: 1.5rem;
  }
  .about-hero-photo {
    flex: 0 0 auto;
    width: 240px;
    max-width: 40%;
  }
  .about-hero-text {
    flex: 1 1 0;
    min-width: 0;
  }
  .about-hero-text .post-title {
    margin-top: 0;
    margin-bottom: 0.5rem;
  }
  .about-hero-text .desc {
    margin-bottom: 1rem;
  }
  .about-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1rem;
  }
  .about-links .btn {
    border: 1px solid var(--global-divider-color);
  }
  .section-title {
    margin-top: 2.5rem;
    padding-bottom: 0.3rem;
    border-bottom: 1px solid var(--global-divider-color);
  }
  .exp-item {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 1.4rem;
  }
  .exp-logo {
    flex: 0 0 auto;
    width: 52px;
  }
  .exp-logo img {
    width: 100%;
    height: auto;
    border-radius: 8px;
  }
  .exp-body {
    flex: 1 1 0;
    min-width: 0;
  }
  .exp-line {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.25rem 1rem;
  }
  .exp-role {
    font-weight: 600;
  }
  .exp-date {
    color: var(--global-text-color-light);
    white-space: nowrap;
  }
  .exp-loc {
    color: var(--global-text-color-light);
    font-size: 0.9rem;
  }
  @media (max-width: 576px) {
    .about-hero {
      flex-direction: column;
      align-items: center;
      gap: 1rem;
      text-align: center;
    }
    .about-hero-photo {
      width: 60%;
      max-width: 240px;
    }
    .about-links {
      justify-content: center;
    }
  }
</style>
