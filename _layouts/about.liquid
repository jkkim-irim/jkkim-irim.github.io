---
layout: default
---

{% comment %}
  Single-page layout for jkkim-irim's personal site (local override of al_folio_core's about.liquid).
  Top: profile photo (left) + name / subtitle / bio / link buttons (right).
  Then, on one page: Publications -> Experience -> Projects. No news, no nav tabs.
{% endcomment %}

<div class="post">
  <article>
    {% comment %} ===== HERO ===== {% endcomment %}
    {% if page.profile and page.profile.image %}
      {% assign profile_image_path = page.profile.image | prepend: 'assets/img/' %}
      {% if page.profile.image_circular %}
        {% assign profile_image_class = 'img-fluid z-depth-1 rounded-circle' %}
      {% else %}
        {% assign profile_image_class = 'img-fluid z-depth-1 rounded' %}
      {% endif %}
      {% capture sizes %}(min-width: 576px) 240px, 60vw{% endcapture %}
      <div class="about-hero">
        <div class="about-hero-photo">
          {%
            include figure.liquid loading="eager" path=profile_image_path class=profile_image_class sizes=sizes alt=page.profile.image
            cache_bust=true
          %}
        </div>
        <div class="about-hero-text">
          <h1 class="post-title">
            {% if site.title == 'blank' %}
              <span class="font-weight-bold">{{ site.first_name }}</span> {{ site.middle_name }}
              {{ site.last_name }}
            {% else %}
              {{ site.title }}
            {% endif %}
          </h1>
          {% if page.subtitle %}<p class="desc">{{ page.subtitle }}</p>{% endif %}
          <div class="clearfix">{{ content }}</div>

          {% comment %} ----- link buttons ----- {% endcomment %}
          {% assign s = site.data.socials %}
          <div class="about-links">
            {% if s.github_username %}
              <a class="btn btn-sm z-depth-0" href="https://github.com/{{ s.github_username }}" target="_blank" rel="noopener" title="GitHub">
                <i class="fa-brands fa-github"></i> GitHub
              </a>
            {% endif %}
            {% if s.linkedin_username %}
              <a class="btn btn-sm z-depth-0" href="https://www.linkedin.com/in/{{ s.linkedin_username }}" target="_blank" rel="noopener" title="LinkedIn">
                <i class="fa-brands fa-linkedin"></i> LinkedIn
              </a>
            {% endif %}
            <a class="btn btn-sm z-depth-0" href="{{ '/cv/' | relative_url }}" title="CV">
              <i class="ai ai-cv"></i> CV
            </a>
            {% if s.scholar_userid %}
              <a class="btn btn-sm z-depth-0" href="https://scholar.google.com/citations?user={{ s.scholar_userid }}" target="_blank" rel="noopener" title="Google Scholar">
                <i class="ai ai-google-scholar"></i> Google Scholar
              </a>
            {% endif %}
          </div>
        </div>
      </div>
    {% endif %}

    {% comment %} ===== PUBLICATIONS ===== {% endcomment %}
    <h2 class="section-title">Publications</h2>
    <div class="publications">
      {% bibliography %}
    </div>

    {% comment %} ===== EXPERIENCE (edit in _data/cv.yml -> sections.Experience) ===== {% endcomment %}
    <h2 class="section-title">Experience</h2>
    {% assign experience = site.data.cv.cv.sections.Experience %}
    {% if experience and experience.size > 0 %}
      <div class="exp-list">
        {% for item in experience %}
          <div class="exp-item">
            <div class="exp-line">
              <span class="exp-role">{{ item.position }}</span>{% if item.company %} · <span class="exp-org">{{ item.company }}</span>{% endif %}
              {% if item.start_date or item.end_date %}
                <span class="exp-date">{{ item.start_date }}{% if item.end_date %} – {{ item.end_date }}{% endif %}</span>
              {% endif %}
            </div>
            {% if item.location %}<div class="exp-loc">{{ item.location }}</div>{% endif %}
            {% if item.summary %}<p class="exp-summary">{{ item.summary }}</p>{% endif %}
            {% if item.highlights %}
              <ul>
                {% for h in item.highlights %}<li>{{ h }}</li>{% endfor %}
              </ul>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    {% else %}
      <p>Experience entries are managed in <code>_data/cv.yml</code> under <code>sections.Experience</code>.</p>
    {% endif %}

    {% comment %} ===== PROJECTS ===== {% endcomment %}
    <h2 class="section-title">Projects</h2>
    <div class="projects">
      <div class="row row-cols-1 row-cols-md-3">
        {% assign sorted_projects = site.projects | sort: 'importance' %}
        {% for project in sorted_projects %}
          {% include projects.liquid %}
        {% endfor %}
      </div>
    </div>
  </article>
</div>

<style>
  /* ===== Claude-inspired warm palette (overrides al-folio theme vars) ===== */
  :root {
    --global-bg-color: #faf9f5;
    --global-text-color: #2b2a27;
    --global-text-color-light: #7a776e;
    --global-theme-color: #c15f3c;
    --global-hover-color: #c15f3c;
    --global-hover-text-color: #ffffff;
    --global-divider-color: rgba(60, 55, 45, 0.12);
    --global-card-bg-color: #ffffff;
    --global-code-bg-color: rgba(193, 95, 60, 0.07);
    --global-highlight-color: #c15f3c;
    --global-footer-bg-color: #2b2a27;
    --global-footer-text-color: #e8e4da;
    --global-footer-link-color: #ffffff;
  }
  html[data-theme="dark"] {
    --global-bg-color: #22201c;
    --global-text-color: #ece8de;
    --global-text-color-light: #a8a499;
    --global-theme-color: #e08a63;
    --global-hover-color: #e08a63;
    --global-hover-text-color: #22201c;
    --global-divider-color: rgba(255, 255, 255, 0.12);
    --global-card-bg-color: #2a2823;
    --global-code-bg-color: rgba(224, 138, 99, 0.1);
    --global-highlight-color: #e08a63;
    --global-footer-bg-color: #191713;
  }

  /* ===== Venue badge colors (badge text always white) ===== */
  .badge {
    color: #ffffff !important;
  }
  .badge.venue-iros {
    background-color: #23406b !important; /* deep blue */
    color: #ffffff !important;
  }
  .badge.venue-preprint {
    background-color: #e0a23c !important; /* amber (orange–yellow) */
    color: #ffffff !important;
  }

  /* ===== Hide the big year group header in publications ===== */
  .publications h2.bibliography {
    display: none;
  }

  .about-hero {
    display: flex;
    align-items: flex-start;
    gap: 2rem;
    margin-bottom: 1.5rem;
  }
  .about-hero-photo {
    flex: 0 0 auto;
    width: 240px;
    max-width: 40%;
  }
  .about-hero-text {
    flex: 1 1 0;
    min-width: 0;
  }
  .about-hero-text .post-title {
    margin-top: 0;
    margin-bottom: 0.5rem;
  }
  .about-hero-text .desc {
    margin-bottom: 1rem;
  }
  .about-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1rem;
  }
  .about-links .btn {
    border: 1px solid var(--global-divider-color);
  }
  .section-title {
    margin-top: 2.5rem;
    padding-bottom: 0.3rem;
    border-bottom: 1px solid var(--global-divider-color);
  }
  .exp-item {
    margin-bottom: 1.2rem;
  }
  .exp-line {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.25rem 1rem;
  }
  .exp-role {
    font-weight: 600;
  }
  .exp-date {
    color: var(--global-text-color-light);
    white-space: nowrap;
  }
  .exp-loc {
    color: var(--global-text-color-light);
    font-size: 0.9rem;
  }
  @media (max-width: 576px) {
    .about-hero {
      flex-direction: column;
      align-items: center;
      gap: 1rem;
      text-align: center;
    }
    .about-hero-photo {
      width: 60%;
      max-width: 240px;
    }
    .about-links {
      justify-content: center;
    }
  }
</style>
